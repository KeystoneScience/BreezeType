{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BreezeType",
  "mainBinaryName": "BreezeType",
  "version": "0.1.6",
  "identifier": "com.pais.breeze.dev",
  "build": {
    "beforeDevCommand": "bun run senko:ensure && bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run senko:ensure && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": " ",
        "width": 980,
        "height": 720,
        "minWidth": 900,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "acceptFirstMouse": true,
        "resizable": true,
        "maximizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "**"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": [
      "resources/**/*"
    ],
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "files": {},
      "hardenedRuntime": true,
      "minimumSystemVersion": "14.0",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist",
      "dmg": {
        "background": "dmg/BreezeTypeDmgBackground.png",
        "windowSize": {
          "width": 760,
          "height": 460
        },
        "appPosition": {
          "x": 190,
          "y": 260
        },
        "applicationFolderPosition": {
          "x": 570,
          "y": 260
        }
      }
    },
    "linux": {
      "rpm": {
        "compression": {
          "type": "none"
        }
      },
      "appimage": {
        "bundleMediaFramework": true,
        "files": {}
      }
    },
    "windows": {
      "signCommand": "trusted-signing-cli -e https://eus.codesigning.azure.net/ -a CJ-Signing -c cjpais-dev -d BreezeType %1"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIwMkNENzFBNjQzRTYzQgpSV1E3NWtPbWNjMENDK0NXY2YwVlNmSGU1VUNJbisrck5vUUtNYklEWGZkS3BXV1Z6WEhIUnAwego=",
      "endpoints": [
        "https://github.com/KeystoneScience/breeze-releases/releases/latest/download/latest.json"
      ]
    }
  }
}
